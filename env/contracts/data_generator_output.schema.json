{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openenv.local/schemas/data_generator_output.schema.json",
  "title": "DataGeneratorOutput",
  "description": "Exact payload contract produced by DataGenerator and consumed by ObservationBuilder.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "experiment_id",
    "primary_metric",
    "aggregate_results",
    "experiment_metadata",
    "available_queries",
    "query_payloads"
  ],
  "properties": {
    "experiment_id": {
      "type": "string",
      "minLength": 1
    },
    "primary_metric": {
      "type": "string",
      "minLength": 1
    },
    "aggregate_results": {
      "$ref": "#/$defs/AggregateResult"
    },
    "experiment_metadata": {
      "$ref": "#/$defs/ExperimentMeta"
    },
    "available_queries": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {
        "enum": [
          "query_subgroup",
          "query_temporal",
          "run_srm_check",
          "query_assignment_overlap",
          "check_network_exposure",
          "inspect_randomization",
          "query_secondary_metrics",
          "compute_mde",
          "flag_contamination",
          "approve_result",
          "request_rerun"
        ]
      }
    },
    "query_payloads": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_srm_check",
        "query_temporal",
        "query_subgroup",
        "query_assignment_overlap",
        "check_network_exposure",
        "inspect_randomization",
        "query_secondary_metrics",
        "compute_mde",
        "peer_experiment_list"
      ],
      "properties": {
        "run_srm_check": {
          "$ref": "#/$defs/SRMResult"
        },
        "query_temporal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DailyResult"
          }
        },
        "query_subgroup": {
          "type": "object",
          "description": "Map from subgroup dimension to rows for that dimension.",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/SubgroupResult"
            }
          }
        },
        "query_assignment_overlap": {
          "$ref": "#/$defs/OverlapMatrix"
        },
        "check_network_exposure": {
          "type": "object",
          "description": "Map of segment name to exposure fraction in [0,1].",
          "additionalProperties": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        },
        "inspect_randomization": {
          "type": "object",
          "description": "Free-form audit details.",
          "additionalProperties": true
        },
        "query_secondary_metrics": {
          "type": "object",
          "description": "Map from metric name to aggregate result.",
          "additionalProperties": {
            "$ref": "#/$defs/AggregateResult"
          }
        },
        "compute_mde": {
          "$ref": "#/$defs/MDEAnalysis"
        },
        "peer_experiment_list": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "$defs": {
    "AggregateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "control_mean",
        "treatment_mean",
        "relative_lift",
        "absolute_lift",
        "p_value",
        "control_count",
        "treatment_count",
        "confidence_interval_lower",
        "confidence_interval_upper"
      ],
      "properties": {
        "control_mean": {"type": "number"},
        "treatment_mean": {"type": "number"},
        "relative_lift": {"type": "number"},
        "absolute_lift": {"type": "number"},
        "p_value": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "control_count": {"type": "integer", "minimum": 0},
        "treatment_count": {"type": "integer", "minimum": 0},
        "confidence_interval_lower": {"type": "number"},
        "confidence_interval_upper": {"type": "number"}
      }
    },
    "ExperimentMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_date",
        "end_date",
        "targeting_rule",
        "intended_split",
        "randomization_unit",
        "platform",
        "experiment_owner",
        "hypothesis"
      ],
      "properties": {
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date"},
        "targeting_rule": {"type": "string"},
        "intended_split": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "randomization_unit": {"type": "string"},
        "platform": {"type": "string"},
        "experiment_owner": {"type": "string"},
        "hypothesis": {"type": "string"}
      }
    },
    "DailyResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "control_mean",
        "treatment_mean",
        "relative_lift",
        "control_count",
        "treatment_count"
      ],
      "properties": {
        "date": {"type": "string", "format": "date"},
        "control_mean": {"type": "number"},
        "treatment_mean": {"type": "number"},
        "relative_lift": {"type": "number"},
        "control_count": {"type": "integer", "minimum": 0},
        "treatment_count": {"type": "integer", "minimum": 0}
      }
    },
    "SubgroupResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "value",
        "control_mean",
        "treatment_mean",
        "relative_lift",
        "control_count",
        "treatment_count"
      ],
      "properties": {
        "dimension": {"type": "string"},
        "value": {"type": "string"},
        "control_mean": {"type": "number"},
        "treatment_mean": {"type": "number"},
        "relative_lift": {"type": "number"},
        "control_count": {"type": "integer", "minimum": 0},
        "treatment_count": {"type": "integer", "minimum": 0}
      }
    },
    "SRMResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_split",
        "actual_split",
        "chi_square_statistic",
        "p_value",
        "srm_detected",
        "severity"
      ],
      "properties": {
        "expected_split": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "actual_split": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "chi_square_statistic": {"type": "number", "minimum": 0.0},
        "p_value": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "srm_detected": {"type": "boolean"},
        "severity": {"enum": ["none", "mild", "severe"]}
      }
    },
    "OverlapMatrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_ids", "overlap_fractions"],
      "properties": {
        "experiment_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "overlap_fractions": {
          "type": "object",
          "description": "Nested map [source_experiment][source_arm] -> fraction or nested object.",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "MDEAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_effect_size",
        "required_sample_per_arm",
        "actual_sample_per_arm",
        "achieved_power",
        "underpowered"
      ],
      "properties": {
        "observed_effect_size": {"type": "number"},
        "required_sample_per_arm": {"type": "integer", "minimum": 0},
        "actual_sample_per_arm": {"type": "integer", "minimum": 0},
        "achieved_power": {"type": "number", "minimum": 0.0, "maximum": 1.0},
        "underpowered": {"type": "boolean"}
      }
    }
  }
}
